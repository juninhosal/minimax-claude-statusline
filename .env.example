# MiniMax API Key
# Get it at: https://platform.minimax.io/user-center/basic-information/interface-key
MINIMAX_API_KEY=your_api_key_here

# Default model (optional, default: MiniMax-M2.7)
# Available models: MiniMax-M2, MiniMax-M2.1, MiniMax-M2.5, MiniMax-M2.7, etc.
MINIMAX_MODEL=MiniMax-M2.7

# Language: en (English) or pt-BR (Portuguese)
LANG=pt-BR
